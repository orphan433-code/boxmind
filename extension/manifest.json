{
  "manifest_version": 3,
  "name": "Boxmind",
  "version": "0.5.1",
  "description": "Умный порядок для ваших ссылок",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Сохранить в Boxmind",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.boxmind.link/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["content/auth-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.boxmind.link/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ]
}
