PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Для production через sslip.io:
# APP_HOST=app.164.92.184.65.sslip.io
# API_HOST=api.164.92.184.65.sslip.io
# ALLOWED_ORIGINS=https://app.164.92.184.65.sslip.io

# Для локального запуска без Docker
DB_POSTGRE_HOST=localhost
DB_POSTGRE_PORT=5436

# В Docker Compose host/port переопределяются на postgres:5432
DB_POSTGRE_USER=petlink
DB_POSTGRE_PASSWORD=petlink
DB_POSTGRE_NAME=petlink

JWT_SECRET=dev-secret-change-in-production
JWT_TTL=24h
OTP_TTL=10m

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Почта для OTP-логина. Если SMTP_HOST пустой — код пишется в логи API.
# Yandex: smtp.yandex.ru, порт 465
# Gmail: smtp.gmail.com, порт 587 + пароль приложения
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Boxmind <noreply@yourdomain.com>
