PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Для production:
# APP_HOST=app.boxmind.link
# API_HOST=api.boxmind.link
# ALLOWED_ORIGINS=https://app.boxmind.link

# Для локального запуска без Docker
DB_POSTGRE_HOST=localhost
DB_POSTGRE_PORT=5436

# В Docker Compose host/port переопределяются на postgres:5432
DB_POSTGRE_USER=petlink
DB_POSTGRE_PASSWORD=petlink
DB_POSTGRE_NAME=petlink

JWT_SECRET=dev-secret-change-in-production
JWT_TTL=24h
OTP_TTL=10m

GEMINI_API_KEY=
# gemini-2.0-flash — быстрее и стабильнее для классификации ссылок
# gemini-2.5-flash — умнее, но иногда медленнее/нестабильнее
GEMINI_MODEL=gemini-2.0-flash

# Почта для OTP-логина. Провайдер выбирается так:
#   1) RESEND_API_KEY задан -> Resend (HTTPS, работает на DigitalOcean)
#   2) иначе SMTP_HOST задан -> SMTP (часто заблокирован на DO/VPS)
#   3) иначе -> код пишется в логи API
MAIL_FROM=Boxmind <onboarding@resend.dev>

# Resend (рекомендуется для прод): https://resend.com
RESEND_API_KEY=

# SMTP (для локалки/своего сервера без блокировок).
# Yandex: smtp.yandex.ru:465, Gmail: smtp.gmail.com:587 + пароль приложения
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Boxmind <noreply@yourdomain.com>
